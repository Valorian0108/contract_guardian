{
  "installCommand": "npm i -g pnpm@10.26.1 && pnpm install",
  "buildCommand": "pnpm --filter @workspace/contract-guardian build",
  "outputDirectory": "artifacts/contract-guardian/dist/public",
  "framework": null,
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
