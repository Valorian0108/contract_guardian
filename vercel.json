{
  "installCommand": "npx --yes pnpm@10.26.1 install",
  "buildCommand": "npx pnpm@10.26.1 --filter @workspace/contract-guardian build && cp -r artifacts/contract-guardian/dist/public ./public",
  "outputDirectory": "public",
  "framework": null,
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
